# ============================================================
# Jerry The Customer Service Bot — .gitignore
# ============================================================

# Environment & secrets
.env
.env.local
.env.production
!.env.example

# Python
backend/venv/
backend/**/__pycache__/
backend/__pycache__/
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/

# Database (local SQLite)
backend/sunsetbot.db
backend/*.db

# Node / Frontend
frontend/node_modules/
frontend/dist/

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Logs
*.log

# ── Explicitly exclude sibling projects / personal files that live in
#    the same parent directory but must NEVER end up in this repo ──
.claude/
skintlabs/
Jerry-The-Customer-Service-Bot-main/
MeatHead/
Prospect/
WonderwallAi-main*/
assets/
docs/email-signature.html
email-signature.html
*.rtf
*.pdf
"claude memory*"
"Louis Constant*"
"Skint Labs*"
